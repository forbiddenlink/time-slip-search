# Algolia Configuration
# Get these from https://www.algolia.com/account/api-keys
NEXT_PUBLIC_ALGOLIA_APP_ID=your_app_id_here
ALGOLIA_SEARCH_API_KEY=your_search_only_api_key_here
ALGOLIA_ADMIN_API_KEY=your_admin_api_key_here

# TMDB API
# Get from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# FRED API (Federal Reserve Economic Data)
# Get from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here
