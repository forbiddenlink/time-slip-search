# Algolia Configuration (Required)
# Get these from https://www.algolia.com/account/api-keys
NEXT_PUBLIC_ALGOLIA_APP_ID=your_app_id_here
ALGOLIA_SEARCH_API_KEY=your_search_only_api_key_here
ALGOLIA_ADMIN_API_KEY=your_admin_api_key_here

# TMDB API (Required for data ingestion)
# Get from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# FRED API - Federal Reserve Economic Data (Required for data ingestion)
# Get from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Optional: Spotify Integration (for playlist export feature)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Optional: Upstash Redis for Production Rate Limiting
# Without these, rate limiting falls back to in-memory store (works but doesn't scale horizontally)
# Get from https://console.upstash.com or Vercel Marketplace > Storage > Upstash Redis
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token
